@article{mangal_robust_2024,
	title = {A {Robust} {Co}-saliency {Object} {Detection} {Model} by {Applying} {CLAHE} and {Otsu} {Segmentation} {Method}},
	volume = {12},
	copyright = {Copyright (c) 2023},
	issn = {2147-6799},
	url = {https://ijisae.org/index.php/IJISAE/article/view/3485},
	abstract = {The co-saliency detection technique is utilized in several applications namely image retrieval, picture annotation, as well as surveillance, among others. Its purpose is to identify the most significant and comparable patterns from a relevant group of images. In this study, there has been proposed a novel approach to co-saliency detection that utilizes the modified ResNet 50 model as a classification model. The contrast-limited adaptive histogram equalization (CLAHE) along with Otsu segmentation techniques were used as pre-processing steps to better identify and isolate prominent objects in the image. These techniques helped the model recognize patterns more efficiently. The Thin ResNet model was fine-tuned and optimized for improved accuracy, and the SGDM optimizer was used for network compilation. For training and testing of the model, we used the Cosal2015 and COCO datasets, with a 70:30 ratio. The proposed model demonstrated superior performance metrics such as MAE as well as F-measure score in comparison to state-of-the-art techniques. This proposed model obtains a high F1-score of 98.6\% along with MAE of 0.034 on widely known Cosal2015 dataset. Also, this model obtained F1-score and MAE scores 94.2\%, and 0.164, respectively on the COCO dataset.},
	language = {en},
	number = {1s},
	urldate = {2026-03-20},
	journal = {International Journal of Intelligent Systems and Applications in Engineering},
	author = {Mangal, Anuj and Garg, Hitendra and Bhatnagar, Charul},
	year = {2024},
	keywords = {Thin ResNet},
	pages = {481--490},
	file = {Full Text PDF:C\:\\Users\\Vishal\\Zotero\\storage\\US6WBHVM\\Mangal et al. - 2024 - A Robust Co-saliency Object Detection Model by Applying CLAHE and Otsu Segmentation Method.pdf:application/pdf},
}

@article{parvati_image_2008,
	title = {Image {Segmentation} {Using} {Gray}-{Scale} {Morphology} and {Marker}-{ControlledWatershed} {Transformation}},
	volume = {2008},
	issn = {1607-887X},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1155/2008/384346},
	doi = {10.1155/2008/384346},
	abstract = {Segmentation, a new method, for color, gray-scale MR medical images, and aerial images, is proposed. The method is based on gray-scale morphology. Edge detection algorithm includes function edge and marker-controlled watershed segmentation. It features the simple algorithm implemented in MATLAB. The watershed segmentation has been proved to be a powerful and fast technique for both contour detection and region-based segmentation. In principle, watershed segmentation depends on ridges to perform a proper segmentation, a property that is often fulfilled in contour detection where the boundaries of the objects are expressed as ridges. For region-based segmentation, it is possible to convert the edges of the objects into ridges by calculating an edge map of the image. Watershed is normally implemented by region growing, based on a set of markers to avoid oversegmentation.},
	language = {en},
	number = {1},
	urldate = {2026-03-20},
	journal = {Discrete Dynamics in Nature and Society},
	author = {Parvati, K. and Prakasa Rao, B. S. and Mariya Das, M.},
