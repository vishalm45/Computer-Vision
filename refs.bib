	pages = {384346},
	file = {Full Text PDF:C\:\\Users\\Vishal\\Zotero\\storage\\94AKYFV2\\Parvati et al. - 2008 - Image Segmentation Using Gray-Scale Morphology and Marker-ControlledWatershed Transformation.pdf:application/pdf;Snapshot:C\:\\Users\\Vishal\\Zotero\\storage\\RSU4BAV7\\384346.html:text/html},
